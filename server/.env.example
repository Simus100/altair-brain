# Copia in server/.env (o nella cartella dell'API) e personalizza.
# NON committare il .env reale (server/.env e gia in .gitignore).

# Obbligatoria
ALTAIR_API_TOKEN=metti-qui-un-token-lungo-e-casuale

# Radice del repo del brain (dati). In deploy con API separata: percorso del clone.
# ALTAIR_REPO_DIR=/home/altair/altair-brain

# graphify: percorso ASSOLUTO (i servizi systemd non ereditano ~/.local/bin)
# GRAPHIFY_BIN=/home/altair/.local/bin/graphify

# Dati scrivibili TENUTI FUORI dal repo, cosi l'auto-update (git reset) non li tocca
# e il feedback sopravvive agli aggiornamenti:
# ALTAIR_MEMORY_DIR=/home/altair/altair-data/memory
# ALTAIR_LESSONS=/home/altair/altair-data/LESSONS.md

# Script di aggiornamento usato da POST /admin/update
# ALTAIR_UPDATE_SCRIPT=/home/altair/altair-brain/server/update_brain.sh

# Timeout comandi graphify (secondi)
# ALTAIR_CMD_TIMEOUT=120
