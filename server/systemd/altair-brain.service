[Unit]
Description=altair-brain API (FastAPI/uvicorn)
After=network-online.target
Wants=network-online.target
OnFailure=altair-notify@%n.service

[Service]
Type=simple
User=altair
WorkingDirectory=/home/altair/altair-api
EnvironmentFile=/home/altair/altair-api/.env
ExecStart=/home/altair/altair-api/.venv/bin/uvicorn app:app --host 127.0.0.1 --port 8000
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
